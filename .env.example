NEXT_PUBLIC_API_BASE_URL=http://localhost:3005/api/v1
NEXT_PUBLIC_INTERNAL_APP_NAME=ATLAS Internal Platform
NEXT_PUBLIC_DEFAULT_TENANT_ID=1
NEXT_PUBLIC_API_TIMEOUT_MS=20000
NEXT_PUBLIC_ATLAS_ENVIRONMENT=local
# cookie (default) = nunca persiste tokens; el backend entrega la sesión en cookies HttpOnly.
# auto = persiste tokens solo si el backend responde tokenType Bearer.
# session = fuerza bearer en sessionStorage. NO usar en producción: un XSS lee la sesión entera.
NEXT_PUBLIC_INTERNAL_AUTH_STORAGE_MODE=cookie
# Configurar solo si el backend exige token CSRF adicional para mutaciones cookie-based.
NEXT_PUBLIC_INTERNAL_CSRF_HEADER_NAME=

# ====================== ALLOWLIST DEL QA LAB ======================
# Hosts extra (host:puerto, coma-separado) a los que el QA Lab puede enviar
# peticiones con la sesión del operador. Las bases propias del portal
# (NEXT_PUBLIC_API_BASE_URL, staging/prod configurados, localhost:3005) ya son
# confiables sin listarlas aquí; esta lista solo abre hosts escritos a mano en
# la opción "Host URL manual". Todo host fuera de la lista se bloquea y no
# recibe el token de sesión.
# Ej.: NEXT_PUBLIC_QA_ALLOWED_HOSTS=api.atlas.internal,staging-api.atlas.internal
NEXT_PUBLIC_QA_ALLOWED_HOSTS=


# ====================== CREDENCIALES DE PRUEBA ======================
# NUNCA pongas credenciales reales aquí: este archivo se versiona en el repo.
# Copia este archivo a .env.local (ignorado por git) y define ahí tus valores locales.
TEST_EMAIL=user@example.invalid
TEST_PASSWORD=replace-me-locally
TEST_TENANT_ID=demo
