NEXT_PUBLIC_API_BASE_URL=http://localhost:3005/api/v1
NEXT_PUBLIC_INTERNAL_APP_NAME=ATLAS Internal Platform
NEXT_PUBLIC_DEFAULT_TENANT_ID=1
NEXT_PUBLIC_API_TIMEOUT_MS=20000
NEXT_PUBLIC_ATLAS_ENVIRONMENT=local
# auto = usa cookies si el backend responde tokenType Cookie; cookie = nunca persiste tokens; session = compatibilidad local con bearer tokens.
NEXT_PUBLIC_INTERNAL_AUTH_STORAGE_MODE=auto
# Configurar solo si el backend exige token CSRF adicional para mutaciones cookie-based.
NEXT_PUBLIC_INTERNAL_CSRF_HEADER_NAME=


# ====================== CREDENCIALES DE PRUEBA ======================
# NUNCA pongas credenciales reales aquí: este archivo se versiona en el repo.
# Copia este archivo a .env.local (ignorado por git) y define ahí tus valores locales.
TEST_EMAIL=user@example.invalid
TEST_PASSWORD=replace-me-locally
TEST_TENANT_ID=demo
